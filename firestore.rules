rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /global_stats/summary {
      allow read, write: if true;
    }
    match /games/{gameId} {
      allow read, write: if true;
    }
    match /player_stats/{playerId} {
      allow read, write: if true;
    }
  }
}
